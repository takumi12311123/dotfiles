    "additional_findings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_sources": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "verification_status",
    "freshness",
    "freshness_detail",
    "confirmed_facts",
    "contradictions",
